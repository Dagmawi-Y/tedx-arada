---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import Hero from "../components/Hero";
import About from "../components/About";
import Speakers from "../components/Speakers";
import Schedule from "../components/Schedule";
import Sponsors from "../components/Sponsors";
---

<Layout title="TEDxArada">
  <Navbar client:load />
  <main>
    <Hero client:load />

    <div id="theme" class="scroll-mt-0">
      <About client:visible />
    </div>

    <div id="speakers" class="scroll-mt-0">
      <Speakers client:visible />
    </div>

    <div id="schedule" class="scroll-mt-0">
      <Schedule client:visible />
    </div>

    <div id="sponsors" class="scroll-mt-0">
      <Sponsors client:visible />
    </div>

    <footer class="bg-ted-black border-t border-white/10 py-12 px-6">
      <div
        class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6"
      >
        <div class="flex flex-col items-center md:items-start gap-2">
          <h4
            class="text-2xl font-sans tracking-tighter leading-none flex items-center"
          >
            <span class="text-ted-red font-black"
              >TED<sup class="text-[0.6em] top-[-0.3em]">x</sup></span
            >
            <span class="text-white font-semibold ml-1">Arada</span>
          </h4>
          <span class="text-white/50 font-sans text-[10px] tracking-wide">
            x = independently organized TED event
          </span>
        </div>

        <div class="flex items-center gap-6 text-sm text-gray-400 font-sans">
          <a href="#" class="hover:text-white transition-colors">Instagram</a>
          <a href="#" class="hover:text-white transition-colors">Twitter</a>
          <a href="#" class="hover:text-white transition-colors">LinkedIn</a>
        </div>
      </div>

      <div
        class="max-w-7xl mx-auto mt-12 pt-6 border-t border-white/5 flex flex-col md:flex-row justify-between items-center text-xs text-gray-500 font-sans"
      >
        <p>This independent TEDx event is operated under license from TED.</p>
        <p class="mt-2 md:mt-0">
          &copy; {new Date().getFullYear()} TEDxArada. All Rights Reserved.
        </p>
      </div>
    </footer>
  </main>
</Layout>
