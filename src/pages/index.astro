---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import Hero from "../components/Hero";
import About from "../components/About";
import Speakers from "../components/Speakers";
import Schedule from "../components/Schedule";
import Sponsors from "../components/Sponsors";
---

<Layout title="TEDxArada">
  <Navbar client:load />
  <main>
    <Hero client:load />

    <div id="theme" class="scroll-mt-24">
      <About client:visible />
    </div>

    <div id="speakers" class="scroll-mt-24">
      <Speakers client:visible />
    </div>

    <div id="schedule" class="scroll-mt-24">
      <Schedule client:visible />
    </div>

    <div id="sponsors" class="scroll-mt-24">
      <Sponsors client:visible />
    </div>

    <footer class="bg-ted-black border-t border-white/10 py-12 px-6">
      <div
        class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6"
      >
        <p class="text-xl font-sans tracking-tighter flex items-center">
          <span class="text-ted-red font-black"
            >TED<sup class="text-[0.6em] top-[-0.3em]">x</sup></span
          >
          <span class="text-white font-normal ml-1">Arada</span>
        </p>
        <p class="text-gray-500 text-sm font-sans text-center md:text-right">
          This independent TEDx event is operated under license from TED.<br />
          &copy; {new Date().getFullYear()} TEDxArada. All Rights Reserved.
        </p>
      </div>
    </footer>
  </main>
</Layout>
