---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import Hero from "../components/Hero";
import About from "../components/About";
import Speakers from "../components/Speakers";
import Schedule from "../components/Schedule";
import Sponsors from "../components/Sponsors";
---

<Layout
  title="Ideas worth spreading"
  description="TEDxArada - Join us at Fendika@Hyatt in Addis Ababa, Ethiopia, for a transformative day of ideas and inspiration. Discover local innovation and global perspectives."
>
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "Event",
      "name": "TEDxArada: From The Heart of Addis Ababa",
      "startDate": "2026-03-14T09:00:00+03:00",
      "endDate": "2026-03-14T18:00:00+03:00",
      "eventStatus": "https://schema.org/EventScheduled",
      "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
      "location": {
        "@type": "Place",
        "name": "Fendika Cultural Center & Hyatt Regency",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Africa Avenue",
          "addressLocality": "Addis Ababa",
          "addressRegion": "Arada",
          "addressCountry": "ET"
        }
      },
      "image": ["https://tedxarada.com/images/og-image.jpg"],
      "description": "TEDxArada is an independently organized TED event in Addis Ababa, Ethiopia, focusing on ideas worth spreading from the local community to the world.",
      "organizer": {
        "@type": "Organization",
        "name": "TEDxArada",
        "url": "https://tedxarada.com"
      }
    }
  </script>
  <Navbar client:load />
  <main>
    <Hero client:load />

    <div id="theme" class="scroll-mt-0 content-auto">
      <About client:visible />
    </div>

    <div id="speakers" class="scroll-mt-0 content-auto">
      <Speakers client:visible />
    </div>

    <div id="schedule" class="scroll-mt-0 content-auto">
      <Schedule client:visible />
    </div>

    <div id="sponsors" class="scroll-mt-0 content-auto">
      <Sponsors client:visible />
    </div>

    <footer class="bg-ted-black border-t border-white/10 py-12 px-6">
      <div
        class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6"
      >
        <div class="flex flex-col items-center md:items-start">
          <img
            src="/images/logo-salon/logo-white.png"
            alt="TEDxArada"
            class="h-8 md:h-10 w-auto object-contain"
          />
          <span
            class="text-white/40 font-sans text-[9px] tracking-tight md:self-end -mt-1"
          >
            x = independently organized TED event
          </span>
        </div>

        <div class="flex items-center gap-6 text-gray-400">
          <a
            href="https://www.instagram.com/tedxarada?igsh=YnJkZHhxYmZkdHBk"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-white transition-colors p-2 -m-2"
            aria-label="Instagram"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a
            href="https://x.com/te_dx56446"
            class="hover:text-white transition-colors p-2 -m-2"
            aria-label="X (formerly Twitter)"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M14.234 10.162L22.977 0h-2.072l-7.591 8.824L7.251 0H.258l9.168 13.343L.258 24H2.33l8.016-9.318L16.749 24h6.993zm-2.837 3.299l-.929-1.329L3.076 1.56h3.182l5.965 8.532l.929 1.329l7.754 11.09h-3.182z"
              ></path>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/company/tedxarada-salon"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-white transition-colors p-2 -m-2"
            aria-label="LinkedIn"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2a2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>
        </div>
      </div>

      <div
        class="max-w-7xl mx-auto mt-12 pt-6 border-t border-white/5 flex flex-col md:flex-row justify-between items-center text-xs text-gray-500 font-sans"
      >
        <p>This independent TEDx event is operated under license from TED.</p>
        <p class="mt-2 md:mt-0">
          &copy; {new Date().getFullYear()} TEDxArada. All Rights Reserved.
        </p>
      </div>
    </footer>
  </main>
</Layout>
