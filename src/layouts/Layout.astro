---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "TEDxArada - Ideas worth spreading in the heart of Addis Ababa.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth bg-ted-black text-ted-white">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts: Inter (Body) & Outfit (Heading) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;700;900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body
    class="antialiased min-h-screen flex flex-col selection:bg-ted-red selection:text-white font-sans"
  >
    <slot />
  </body>
</html>
